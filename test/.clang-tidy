# Test-only clang-tidy override.
#
# This file shadows the root .clang-tidy for translation units compiled under
# test/. It inherits the same check set (via CheckOptions) and disables:
#
#   bugprone-unchecked-optional-access
#     clang-tidy's flow analysis cannot prove optionals are engaged after a
#     doctest REQUIRE(...) macro, so it false-positives on the common test
#     idiom:
#         REQUIRE(opt.has_value());  // or REQUIRE(opt)
#         ... opt.value() ...        // flagged despite the guard above
#     This is a documented limitation (llvm/llvm-project#181737). Every deref
#     site in the tests IS guarded by a preceding REQUIRE; the check simply
#     can't see through the macro. The check stays enabled for library headers
#     (root .clang-tidy) where it works reliably.
#
#   clang-diagnostic-c2y-extensions
#     doctest's DOCTEST_ANONYMOUS macro expands __COUNTER__ at the call site
#     (in test files), and clang 22+ flags __COUNTER__ as a C2y extension.
#     The macro is defined in doctest.h (now a SYSTEM header, so its internal
#     warnings are suppressed), but the diagnostic attaches to the expansion
#     point in our test code. doctest's use of __COUNTER__ is correct and not
#     something we can change.
#
# See root .clang-tidy for the full rationale on the other disabled checks.

Checks: >
  -*,
  bugprone-*,
  modernize-*,
  performance-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-throwing-static-initialization,
  -bugprone-crtp-constructor-accessibility,
  -bugprone-unchecked-optional-access,
  -clang-diagnostic-c2y-extensions,
  -modernize-avoid-c-arrays,
  -modernize-raw-string-literal,
  -modernize-use-default-member-init,
  -modernize-use-designated-initializers,
  -modernize-use-integer-sign-comparison,
  -modernize-use-ranges,
  -modernize-use-starts-ends-with,
  -modernize-use-trailing-return-type,
  -modernize-use-nodiscard,
  -modernize-concat-nested-namespaces,
  -performance-enum-size,
  -readability-*,
  +readability-container-data-pointer,
  +readability-delete-null-pointer,
  +readability-duplicate-conditional,
  +readability-inconsistent-declaration-parameter-name,
  +readability-non-const-parameter,
  +readability-qualified-auto,
  +readability-redundant-control-flow,
  +readability-redundant-string-cstr,
  +readability-redundant-string-init,
  +readability-simplify-boolean-expr,
  +readability-static-definition-in-anonymous-namespace,
  +readability-string-compare,
  +readability-uniqueptr-delete-release,
  +readability-else-after-return

WarningsAsErrors: '*'

HeaderFilterRegex: 'include/.*'

FormatStyle: file
